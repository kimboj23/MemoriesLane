# Copy to .env — never commit .env to version control.

# --- Server ---
PORT=3001
NODE_ENV=development

# Bind address. Use 127.0.0.1 behind a reverse proxy (nginx/Caddy).
# Never bind to 0.0.0.0 unless TLS terminates at the same process.
BIND_ADDR=127.0.0.1

# --- CORS ---
# Comma-separated list of allowed origins.
# In local dev the HTML opens as file://, which sends Origin: null — include "null" here.
# In production set this to your actual domain: https://example.com
ALLOWED_ORIGINS=null

# --- Database ---
# Primary store is Supabase Postgres (session pooler, IPv4, TLS). URL-encode
# special chars in the password (& -> %26). For a fully-local DB instead, use:
#   DATABASE_URL=postgresql://memorylane:memorylane@localhost:5432/memorylane
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres
UPLOADS_DIR=./uploads

# --- Supabase Storage (primary photo store; private bucket) ---
# Leave SUPABASE_* unset to fall back to local-disk photo storage (dev only).
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace_me_with_service_role_key
SUPABASE_BUCKET=memory-photos

# --- Rate limiting (IP-free) ---
# A random secret used to derive per-window pseudonyms from client IPs.
# Rotating this key every N days automatically expires old counters.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
RATE_HMAC_SECRET=replace_me_with_64_hex_chars

# --- Admin authentication ---
# SHA-256 hash of the admin Bearer token.
# 1. Choose a strong random token: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 2. Hash it:                       node -e "const c=require('crypto');console.log(c.createHash('sha256').update('YOUR_TOKEN').digest('hex'))"
# 3. Store the HASH here, keep the raw token somewhere safe (password manager).
ADMIN_TOKEN_HASH=replace_me_with_sha256_hex

# --- Optional: Arweave / IPFS gateway for pinning approved memories ---
# ARWEAVE_GATEWAY=https://arweave.net
